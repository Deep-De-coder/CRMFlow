# Salesforce credentials
# Get these from: Setup → Apps → App Manager → New Connected App
# OR: Setup → My Personal Information → Reset Security Token
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_security_token
SF_DOMAIN=login
# Use SF_DOMAIN=test for sandbox accounts

# App
APP_ENV=development
LOG_LEVEL=INFO
